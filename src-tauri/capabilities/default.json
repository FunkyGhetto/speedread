{
  "identifier": "default",
  "description": "Default capabilities for SpeedRead",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "http:default",
    "http:allow-fetch",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:allow-read-dir",
    "fs:allow-appdata-meta-recursive",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive"
  ]
}
